#!/bin/sh
# Embedded terminal that launches Claude Code, then drops to an interactive login
# shell. POSIX-sh compatible (macOS + Linux); the server execs it via /bin/sh.
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:$HOME/.bun/bin:$PATH"
cd "${NERV_PROJECT:-$HOME}" 2>/dev/null
clear 2>/dev/null
if command -v claude >/dev/null 2>&1; then
  claude
fi
SH="${SHELL:-/bin/bash}"
exec "$SH" -il
